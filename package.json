{
  "name": "cypress-js-e2e-framework",
  "version": "1.0.0",
  "description": "Cypress JavaScript E2E automation framework with Page Object Model, environment configuration, reporting, and CI/CD examples using CircleCI and Jenkins.",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:verify": "cypress verify",
    "test": "cypress run",
    "test:smoke": "cypress run --spec 'cypress/e2e/smoke/**/*.cy.js'",
    "test:regression": "cypress run --spec 'cypress/e2e/regression/**/*.cy.js'",
    "test:chrome": "cypress run --browser chrome",
    "test:edge": "cypress run --browser edge",
    "test:headed": "cypress run --headed --browser chrome",
    "report:merge": "mochawesome-merge reports/mochawesome/*.json > reports/mochawesome/merged-report.json",
    "report:html": "marge reports/mochawesome/merged-report.json --reportDir reports/mochawesome --inline",
    "report:generate": "npm run report:merge && npm run report:html",
    "clean:reports": "rm -rf reports cypress/screenshots cypress/videos cypress/downloads"
  },
  "keywords": [
    "cypress",
    "javascript",
    "e2e-testing",
    "qa-automation",
    "page-object-model",
    "circleci",
    "jenkins"
  ],
  "author": "Matias Galvez",
  "license": "MIT",
  "devDependencies": {
    "cypress": "^15.17.0",
    "cypress-multi-reporters": "^1.6.4",
    "dotenv": "^16.4.7",
    "mocha-junit-reporter": "^2.2.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^5.0.0",
    "mochawesome-report-generator": "^6.2.0"
  }
}
